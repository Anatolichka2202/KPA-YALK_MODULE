CFLAGS   = $(INCS) -g3 -DBUILDING_DLL=1
DEL      = D:\Compilers\Embarcadero\Dev-Cpp\devcpp.exe INTERNAL_DEL
LIBDEF   = ../../../../Bin/libLusbapi64.def
STATIC   = ../../../../Lib/MinGW/libLusbapi64.a

.PHONY: all all-before all-after clean clean-custom

all: all-before $(BIN) all-after

clean: clean-custom
